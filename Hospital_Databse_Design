drop trigger check_new_appointment;

delimiter $$
create trigger check_new_appointment
before insert on Aapointment
for each row 
begin

	if new.appointment_time < now() then
		signal sqlstate '45000'
		set message_text = 'Error: Appointment cannot be in the past';
    end if;
    
    if exists
    (
		select * from aapointment
		where doctor_id = new.doctor_id and
		appointment_time = new.appointment_time and
        status in('Scheduled')
    )
		then
		signal sqlstate '45000'
		set message_text = 'Error: Doctor has alredy an appointment at this time';
        
    end if;
end $$
