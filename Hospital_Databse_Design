delimiter //
create procedure revenue_by_month(in p_year int, in p_month int)
begin
		select d1.department_name as department,
        sum(amount) as Total_Revenue
        from bills as b
        join 
        aapointment a on b.aapointment_id = a.aapointment_id
        join
        doctors as d on a.doctor_id = d.doctor_id
        join
        department as d1 on d1.department_id = d.doctor_id
        where month(b.bill_date)=p_month and year(b.bill_date)= p_year
        group by d1.department_name;



end //
delimiter ;

 call revenue_by_month(2025,6);
 call revenue_by_month(2024,6);
 call revenue_by_month(2025,5);


















