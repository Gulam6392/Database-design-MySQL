create database Hospital_db ;
use Hospital_db;

-- create table Department

create table Department(
department_id int auto_increment primary key,
department_name varchar(50) not null
);

-- create table Doctors

create table Doctors(
doctor_id int auto_increment primary key,
name varchar(50),
specialization varchar(50),
role varchar(50),
department_id int ,
foreign key (department_id) references Department(department_id)
);

-- create table Patients

create table patients(
patient_id int auto_increment primary key,
name varchar(50),
DOB date,
gender varchar(1),
phone varchar(15),
check(gender in("M","F","O"))
);

-- Create table Aapointment

create table aapointment(
aapointment_id int auto_increment primary key,
patient_id int,
doctor_id int,
appointment_time datetime default current_timestamp,
status varchar(50),
foreign key (patient_id) references patients (patient_id),
foreign key (doctor_id) references doctors (doctor_id),
check(status in("Scheduled","Completed","Cancelled"))
);

-- create Prescriptions
create table Prescriptions(
Prescriptions_id int auto_increment primary key,
aapointment_id int,
medication varchar(100),
dosage varchar(50),
foreign key (aapointment_id) references aapointment(aapointment_id)

);

-- create table Bills

create table bills(
bill_id int auto_increment primary key,
aapointment_id int,
amount decimal(10,2),
paid tinyint(1),
bill_date datetime default current_timestamp,
foreign key (aapointment_id) references aapointment(aapointment_id)
);

-- create table labreport

create table labreport(
report_id int auto_increment primary key,
aapointment_id int,
report_data text,
create_date datetime default current_timestamp,
foreign key (aapointment_id) references aapointment(aapointment_id)

);


